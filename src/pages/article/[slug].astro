---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  const sortedPosts = [...posts].sort((a, b) => {
    const slugA = a.data.slug || a.slug;
    const slugB = b.data.slug || b.slug;
    return slugA.localeCompare(slugB);
  });

  return sortedPosts.map((post, index) => {
    const prevPost = index > 0 ? sortedPosts[index - 1] : null;
    const nextPost = index < sortedPosts.length - 1 ? sortedPosts[index + 1] : null;
    return {
      params: { slug: post.data.slug || post.slug },
      props: { 
        post,
        prevPost,
        nextPost
      },
    };
  });
}

const { post, prevPost, nextPost } = Astro.props;
const { Content } = await render(post);

const prevSlug = prevPost ? (prevPost.data.slug || prevPost.slug) : null;
const prevTitle = prevPost ? (prevPost.data.title || prevPost.slug) : null;
const nextSlug = nextPost ? (nextPost.data.slug || nextPost.slug) : null;
const nextTitle = nextPost ? (nextPost.data.title || nextPost.slug) : null;
---

<BaseLayout title={`${post.data.title} - 挖洞吧`} css={['article.css']}>
<div class="container">
    <div class="side-space"></div>
    <div class="main">
        <div class="top-bar">
            <div class="top-left">
                <button class="back-btn" onclick="goBackToList('/articles')">
                    <span>←</span>
                    <span data-cn="返回" data-en="Back">返回</span>
                </button>
                <div class="header">
                    <h1 data-cn="挖洞吧" data-en="Hack Zone">挖洞吧</h1>
                    <p data-cn="漏洞分析与复现" data-en="Vulnerability Analysis and Reproduction">漏洞分析与复现</p>
                </div>
            </div>
            <div class="language-box">
                <button class="language-btn" id="currentLang"><span class="lang-icon">🌐</span><span class="lang-text">简体中文</span></button>
                <div class="language-dropdown">
                    <button class="language-item" onclick="switchLanguage('zh')">简体中文</button>
                    <button class="language-item" onclick="switchLanguage('en')">English</button>
                </div>
            </div>
        </div>
        <div class="content-layout">
            <div class="article">
                <h2 class="article-title">{post.data.title}</h2>
                <div class="markdown-content">
                  <Content />
                </div>
            </div>
            <div class="right-box"></div>
        </div>
        <div class="footer-bar">
            <button class="footer-btn page-btn" onclick="goBackToList('/articles')" data-cn="← 返回列表" data-en="← Back to List">← 返回列表</button>
            {prevSlug ? (
                <button class="footer-btn page-btn prev-btn" data-slug="{prevSlug}" onclick="navigateToArticle(this)">
                    <span>‹</span> <span data-cn="上一篇" data-en="Previous">上一篇</span>
                    <span class="post-title">{prevTitle}</span>
                </button>
            ) : (
                <button class="footer-btn page-btn disabled" disabled>
                    <span>‹</span> <span data-cn="上一篇" data-en="Previous">上一篇</span>
                </button>
            )}
            {nextSlug ? (
                <button class="footer-btn page-btn next-btn" data-slug="{nextSlug}" onclick="navigateToArticle(this)">
                    <span data-cn="下一篇" data-en="Next">下一篇</span> <span>›</span>
                    <span class="post-title">{nextTitle}</span>
                </button>
            ) : (
                <button class="footer-btn page-btn disabled" disabled>
                    <span data-cn="下一篇" data-en="Next">下一篇</span> <span>›</span>
                </button>
            )}
        </div>
    </div>
</div>

<div class="scroll-float">
    <button class="scroll-btn-top" onclick="scrollToTop()" title="置顶">&#x2B06;&#xFE0F;</button>
    <button class="scroll-btn-bottom" onclick="scrollToBottom()" title="置底">&#x2B07;&#xFE0F;</button>
</div>

<script>
function navigateTo(url) {
    window.location.href = url;
}

function navigateToArticle(btn) {
    var slug = btn.getAttribute('data-slug');
    if (slug) {
        window.location.href = '/article/' + slug;
    }
}

function scrollToTop() {
    window.scrollTo({ top: 0, behavior: 'smooth' });
}

function scrollToBottom() {
    window.scrollTo({ top: document.body.scrollHeight, behavior: 'smooth' });
}
</script>
</BaseLayout>