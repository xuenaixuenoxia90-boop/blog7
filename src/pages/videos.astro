---
import BaseLayout from '../layouts/BaseLayout.astro';
import videosData from '../content/video/videos.json';
import { readFileSync } from 'fs';
import path from 'path';

const swubPath = path.join(process.cwd(), 'src', 'content', 'pictures', 'SWUB.md');
const swubContent = readFileSync(swubPath, 'utf-8');
const imageRegex = /!\[img\]\(([^)]+)\)/g;
const pictureUrls = [];
let match;
while ((match = imageRegex.exec(swubContent)) !== null) {
  pictureUrls.push(match[1]);
}

function getPictureByIndex(index) {
  if (pictureUrls.length === 0) {
    return `https://picsum.photos/400/300?${index}`;
  }
  return pictureUrls[index % pictureUrls.length];
}

const videosPerPage = 9;
const totalPages = Math.ceil(videosData.length / videosPerPage);
const firstPageVideos = videosData.slice(0, videosPerPage);
---

<BaseLayout title="拉杆吧" css={['videos.css']}>
<div class="page">
    <div class="side-ad"></div>
    <div class="main">
        <div class="header">
            <div class="top-bar">
                <button class="back-btn" onclick="goBackToHome()">
                    ←
                    <span data-cn="返回" data-en="Back">返回</span>
                </button>
                <div class="title-box">
                    <div class="title" data-cn="拉杆吧" data-en="SWUB Zone">拉杆吧</div>
                    <div class="sub-title" data-cn="唤醒国男的街健梦！" data-en="Wake up your street workout dream!">唤醒国男的街健梦！</div>
                </div>
                <div class="language-box">
                    <button class="language-btn" id="currentLang"><span class="lang-icon">🌐</span><span class="lang-text">简体中文</span></button>
                    <div class="language-dropdown">
                        <button class="language-item" onclick="switchLanguage('zh')">简体中文</button>
                        <button class="language-item" onclick="switchLanguage('en')">English</button>
                    </div>
                </div>
            </div>
            <div class="search-row">
                <div class="search-box">
                    <input type="text" id="searchInput" placeholder="搜索视频标题..." />
                </div>
                <button class="search-btn" data-cn="🔍 搜索" data-en="🔍 Search">🔍 搜索</button>
            </div>
        </div>
        <div class="video-wrapper">
            <div class="video-grid" id="videoGrid">
                {firstPageVideos.map((video, index) => {
              const title = video.title || video.id;
              const cover = getPictureByIndex(index);
              return (
                <div class="video-card" data-id={video.id} data-cover={cover} data-title={title} onclick="window.openVideo(this.dataset.id)">
                    <div class="video-cover">
                        <img src={cover} />
                        <div class="play-icon">▶</div>
                    </div>
                    <div class="video-info">
                        <div class="video-title">{title}</div>
                    </div>
                </div>
              );
            })}
            </div>
        </div>
        <div class="pagination" id="pagination">
            <button class="page-btn prev-btn" id="prevBtn">
                <span>‹</span> 上一页
            </button>
            <span class="page-label">第</span>
            <select class="page-select" id="pageSelect">
                {Array.from({ length: totalPages }, (_, i) => (
                    <option value={i + 1}>{i + 1}</option>
                ))}
            </select>
            <span class="page-label">页 / 共 {totalPages} 页</span>
            <button class="page-btn next-btn" id="nextBtn">
                下一页 <span>›</span>
            </button>
        </div>
    </div>
    <div class="side-ad"></div>
</div>

<!-- 总页数数据 -->
<script id="total-pages" type="application/json">{totalPages}</script>

<script is:inline define:vars={{ totalPages }}>
(function() {
    var pageCache = { 1: [] };
    var currentPage = 1;
    var prevBtn = null;
    var nextBtn = null;
    var pageSelect = null;
    
    console.log('初始 totalPages:', totalPages);
    
    function renderCards(videos) {
        var grid = document.getElementById('videoGrid');
        grid.innerHTML = '';
        for (var i = 0; i < videos.length; i++) {
            var v = videos[i];
            var card = document.createElement('div');
            card.className = 'video-card';
            card.setAttribute('data-id', v.id);
            card.setAttribute('data-cover', v.cover || '');
            card.setAttribute('data-title', v.title);
            
            var coverHtml = '<div class="video-cover"><img src="' + (v.cover || ('https://picsum.photos/400/300?' + v.id)) + '" /><div class="play-icon">▶</div></div>';
            var infoHtml = '<div class="video-info"><div class="video-title">' + v.title + '</div></div>';
            card.innerHTML = coverHtml + infoHtml;
            
            (function(id) {
                card.addEventListener('click', function() {
                    sessionStorage.setItem('videosPage', String(currentPage));
                    window.location.href = '/video/' + id;
                });
            })(v.id);
            
            grid.appendChild(card);
        }
    }
    
    function updateUI(pageNum) {
        if (pageSelect) {
            pageSelect.value = String(pageNum);
        }
        if (prevBtn) prevBtn.disabled = (pageNum <= 1);
        if (nextBtn) nextBtn.disabled = (totalPages <= 1 || pageNum >= totalPages);
    }
    
    window.switchToPage = function(pageNum) {
        console.log('switchToPage 被调用，页码:', pageNum, '总页数:', totalPages);
        if (pageNum < 1 || pageNum > totalPages) {
            console.log('页码超出范围，取消切换');
            return;
        }
        currentPage = pageNum;
        updateUI(pageNum);
        
        if (pageCache[pageNum]) {
            console.log('从缓存加载页码:', pageNum);
            var grid = document.getElementById('videoGrid');
            grid.innerHTML = '';
            for (var i = 0; i < pageCache[pageNum].length; i++) {
                grid.appendChild(pageCache[pageNum][i]);
            }
            return;
        }
        
        console.log('从服务器加载页码:', pageNum);
        fetch('/api/videos/' + pageNum + '.json')
            .then(function(res) { return res.json(); })
            .then(function(data) {
                renderCards(data.videos);
                
                var grid = document.getElementById('videoGrid');
                var cards = [];
                var allCards = grid.querySelectorAll('.video-card');
                for (var j = 0; j < allCards.length; j++) {
                    cards.push(allCards[j]);
                }
                pageCache[pageNum] = cards;
            })
            .catch(function() {});
    };
    
    document.addEventListener('DOMContentLoaded', function() {
        console.log('DOMContentLoaded 后 totalPages:', totalPages);
        
        prevBtn = document.getElementById('prevBtn');
        nextBtn = document.getElementById('nextBtn');
        pageSelect = document.getElementById('pageSelect');
        
        var firstPageCards = document.querySelectorAll('#videoGrid .video-card');
        var cachedCards = [];
        for (var i = 0; i < firstPageCards.length; i++) {
            var card = firstPageCards[i];
            (function(c) {
                c.addEventListener('click', function() {
                    sessionStorage.setItem('videosPage', String(currentPage));
                    window.location.href = '/video/' + c.dataset.id;
                });
            })(card);
            cachedCards.push(card);
        }
        pageCache[1] = cachedCards;
        
        updateUI(currentPage);
        
        if (pageSelect) {
            pageSelect.addEventListener('change', function() {
                var pageNum = parseInt(this.value);
                window.switchToPage(pageNum);
            });
        }
        
        if (prevBtn) {
            prevBtn.addEventListener('click', function(e) {
                e.preventDefault();
                window.switchToPage(currentPage - 1);
            });
        }
        
        if (nextBtn) {
            nextBtn.addEventListener('click', function(e) {
                e.preventDefault();
                window.switchToPage(currentPage + 1);
            });
        }
        
        // 恢复之前保存的页码
        var savedPage = sessionStorage.getItem('videosPage');
        console.log('恢复页码检查:', savedPage);
        if (savedPage) {
            var pageNum = parseInt(savedPage);
            sessionStorage.removeItem('videosPage');
            console.log('准备切换到页码:', pageNum);
            if (pageNum > 1 && pageNum <= totalPages) {
                window.switchToPage(pageNum);
            }
        }
    });
    
    // 处理页面恢复（bfcache）
    window.addEventListener('pageshow', function(event) {
        if (event.persisted) {
            console.log('页面从缓存恢复, totalPages:', totalPages);
            var savedPage = sessionStorage.getItem('videosPage');
            console.log('恢复页码检查:', savedPage);
            if (savedPage) {
                var pageNum = parseInt(savedPage);
                sessionStorage.removeItem('videosPage');
                console.log('准备切换到页码:', pageNum);
                if (pageNum > 1 && pageNum <= totalPages) {
                    setTimeout(function() {
                        window.switchToPage(pageNum);
                    }, 100);
                }
            }
        }
    });

    window.openVideo = function(id) {
        sessionStorage.setItem('videosPage', String(currentPage));
        window.location.href = '/video/' + id;
    };
})();
</script>
</BaseLayout>
