---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('blog');
// 按 slug 编号排序
const posts = [...allPosts].sort((a, b) => {
  const slugA = a.data.slug || a.slug;
  const slugB = b.data.slug || b.slug;
  return slugA.localeCompare(slugB);
});
const postsPerPage = 9;
const totalPages = Math.ceil(posts.length / postsPerPage);
---

<BaseLayout title="挖洞吧" css={['articles.css']}>
<div class="container" id="mainContainer">
    <div class="side-space"></div>
    <div class="main">
        <div class="top-bar">
            <div class="top-left">
                <button class="back-btn" onclick="goBackToHome()">
                    <span class="arrow">←</span>
                    <span data-cn="返回" data-en="Back">返回</span>
                </button>
                <div class="header">
                    <h1 data-cn="挖洞吧" data-en="Hack Zone">挖洞吧</h1>
                    <p data-cn="自己挖 + 市面上大部分漏洞报告，只要小白一直Go就一直更新！" data-en="Self-discovered vulnerabilities + most public reports. As long as GOGO keeps going, updates never stop!">
                        自己挖 + 市面上大部分漏洞报告，只要小白一直Go就一直更新！
                    </p>
                </div>
            </div>
            <div class="language-box">
                <button class="language-btn" id="currentLang"><span class="lang-icon"></span><span class="lang-text">简体中文</span></button>
                <div class="language-dropdown">
                    <button class="language-item" onclick="switchLanguage('zh')">简体中文</button>
                    <button class="language-item" onclick="switchLanguage('en')">English</button>
                </div>
            </div>
        </div>
        <div class="toolbar">
            <input type="text" id="searchInput" placeholder="搜索漏洞标题..." />
            <button class="search-btn" data-cn="🔍 搜索" data-en=" Search"> 搜索</button>
        </div>
        <div class="article-grid" id="articleGrid">
            {posts.map((post, index) => {
              const title = post.data.title || post.slug;
              const cover = post.data.cover || '';
              const urlSlug = post.data.slug || post.slug;
              const pageNum = Math.floor(index / postsPerPage) + 1;
              return (
                <div class={pageNum > 1 ? 'card hidden' : 'card'} data-slug={urlSlug} data-page={pageNum} onclick="navigateTo('/article/' + this.dataset.slug)">
                  <img src={cover || `https://picsum.photos/300/200?${urlSlug}`} alt={title} />
                  <h3>{title}</h3>
                </div>
              );
            })}
        </div>
        <div class="pagination" id="pagination">
            <button class="page prev-btn" id="prevBtn">&lt;</button>
            {Array.from({ length: totalPages }, (_, i) => (
              <button class={`page ${i === 0 ? 'active' : ''}`} data-page={i + 1}>{i + 1}</button>
            ))}
            <button class="page next-btn" id="nextBtn">&gt;</button>
        </div>
    </div>
    <div class="side-space"></div>
</div>

<!-- 警告框 -->
<div class="warning-overlay" id="warningOverlay">
    <div class="warning-box">
        <div class="warning-icon">️</div>
        <div class="warning-title">警告</div>
        <div class="warning-text">公开漏洞报告分享平台收录的所有漏洞均已修复，仅用于网络安全学习，严禁用于任何非法用途！</div>
        <div class="warning-btns">
            <button class="warning-btn confirm-btn" onclick="closeWarning()">我已知悉，确认进入</button>
            <button class="warning-btn back-btn" onclick="backToHome()">返回</button>
        </div>
    </div>
</div>

<script is:inline>
(function() {
    // 切换页面
    window.switchToPage = function(pageNum) {
        var cards = document.querySelectorAll('.card[data-page]');
        var pageBtns = document.querySelectorAll('.page[data-page]');
        
        // 隐藏所有卡片
        for (var i = 0; i < cards.length; i++) {
            cards[i].style.display = 'none';
        }
        
        // 显示目标页的卡片
        for (var j = 0; j < cards.length; j++) {
            if (cards[j].getAttribute('data-page') === String(pageNum)) {
                cards[j].style.display = 'flex';
            }
        }
        
        // 更新按钮高亮
        for (var k = 0; k < pageBtns.length; k++) {
            pageBtns[k].classList.remove('active');
        }
        var activeBtn = document.querySelector('.page[data-page="' + pageNum + '"]');
        if (activeBtn) activeBtn.classList.add('active');
    };
    
    // 绑定事件
    document.addEventListener('DOMContentLoaded', function() {
        // 警告框
        var hasSeenWarning = sessionStorage.getItem('hasSeenArticlesWarning');
        var isReturning = sessionStorage.getItem('isReturningFromOtherPage');
        if (!hasSeenWarning && !isReturning) {
            document.getElementById('warningOverlay').classList.add('active');
            sessionStorage.setItem('hasSeenArticlesWarning', 'true');
        }
        
        // 页码按钮
        var pageBtns = document.querySelectorAll('.page[data-page]');
        for (var i = 0; i < pageBtns.length; i++) {
            pageBtns[i].addEventListener('click', function() {
                var pageNum = parseInt(this.getAttribute('data-page'));
                window.switchToPage(pageNum);
            });
        }
        
        // 上一页
        var prevBtn = document.getElementById('prevBtn');
        if (prevBtn) {
            prevBtn.addEventListener('click', function() {
                var activeBtn = document.querySelector('.page.active');
                if (activeBtn) {
                    var current = parseInt(activeBtn.getAttribute('data-page'));
                    if (current > 1) window.switchToPage(current - 1);
                }
            });
        }
        
        // 下一页
        var nextBtn = document.getElementById('nextBtn');
        if (nextBtn) {
            nextBtn.addEventListener('click', function() {
                var activeBtn = document.querySelector('.page.active');
                if (activeBtn) {
                    var current = parseInt(activeBtn.getAttribute('data-page'));
                    var totalBtns = document.querySelectorAll('.page[data-page]').length;
                    if (current < totalBtns) window.switchToPage(current + 1);
                }
            });
        }
    });
})();

function closeWarning() {
    document.getElementById('warningOverlay').classList.remove('active');
}

function backToHome() {
    sessionStorage.removeItem('isReturningFromOtherPage');
    window.location.href = '/';
}
</script>
</BaseLayout>
