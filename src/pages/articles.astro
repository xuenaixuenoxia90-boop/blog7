---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const posts = await getCollection('blog');
const postsPerPage = 9;
const totalPages = Math.ceil(posts.length / postsPerPage);
const firstPagePosts = posts.slice(0, postsPerPage);
---

<BaseLayout title="挖洞吧" css={['articles.css']}>
<div class="container" id="mainContainer">
    <div class="side-space"></div>
    <div class="main">
        <div class="top-bar">
            <div class="top-left">
                <button class="back-btn" onclick="goBackToHome()">
                    <span class="arrow">←</span>
                    <span data-cn="返回" data-en="Back">返回</span>
                </button>
                <div class="header">
                    <h1 data-cn="挖洞吧" data-en="Hack Zone">挖洞吧</h1>
                    <p data-cn="自己挖 + 市面上大部分漏洞报告，只要小白一直Go就一直更新！" data-en="Self-discovered vulnerabilities + most public reports. As long as GOGO keeps going, updates never stop!">
                        自己挖 + 市面上大部分漏洞报告，只要小白一直Go就一直更新！
                    </p>
                </div>
            </div>
            <div class="language-box">
                <button class="language-btn" id="currentLang"><span class="lang-icon">🌐</span><span class="lang-text">简体中文</span></button>
                <div class="language-dropdown">
                    <button class="language-item" onclick="switchLanguage('zh')">简体中文</button>
                    <button class="language-item" onclick="switchLanguage('en')">English</button>
                </div>
            </div>
        </div>
        <div class="toolbar">
            <input type="text" id="searchInput" placeholder="搜索漏洞标题..." />
            <button class="search-btn" data-cn="🔍 搜索" data-en=" Search"> 搜索</button>
        </div>
        <div class="article-grid" id="articleGrid">
            {firstPagePosts.map((post) => {
              const title = post.data.title || post.slug;
              const cover = post.data.cover || '';
              const urlSlug = post.data.slug || post.slug;
              return (
                <div class="card" data-slug={urlSlug} onclick="navigateTo('/article/' + this.dataset.slug)">
                  <img src={cover || `https://picsum.photos/300/200?${urlSlug}`} alt={title} />
                  <h3>{title}</h3>
                </div>
              );
            })}
        </div>
        <div class="pagination" id="pagination">
            <button class="page prev-btn" id="prevBtn">&lt;</button>
            {Array.from({ length: totalPages }, (_, i) => (
              <button class={`page ${i === 0 ? 'active' : ''}`} data-page={i + 1}>{i + 1}</button>
            ))}
            <button class="page next-btn" id="nextBtn">&gt;</button>
        </div>
    </div>
    <div class="side-space"></div>
</div>

<!-- 警告框 -->
<div class="warning-overlay" id="warningOverlay">
    <div class="warning-box">
        <div class="warning-icon">️</div>
        <div class="warning-title">警告</div>
        <div class="warning-text">公开漏洞报告分享平台收录的所有漏洞均已修复，仅用于网络安全学习，严禁用于任何非法用途！</div>
        <div class="warning-btns">
            <button class="warning-btn confirm-btn" onclick="closeWarning()">我已知悉，确认进入</button>
            <button class="warning-btn back-btn" onclick="backToHome()">返回</button>
        </div>
    </div>
</div>

<!-- 存储所有文章数据 -->
<script id="posts-data" type="application/json">{JSON.stringify(posts.map(p => ({ title: p.data.title || p.slug, cover: p.data.cover || '', urlSlug: p.data.slug || p.slug })))}</script>

<script is:inline>
var allPostsData = [];
var dataEl = document.getElementById('posts-data');
if (dataEl) {
    try {
        allPostsData = JSON.parse(dataEl.textContent);
        console.log('Loaded ' + allPostsData.length + ' posts');
    } catch(e) {
        console.error('Error parsing posts data:', e);
    }
}

document.addEventListener("DOMContentLoaded", function() {
    var hasSeenWarning = sessionStorage.getItem('hasSeenArticlesWarning');
    var isReturning = sessionStorage.getItem('isReturningFromOtherPage');
    
    if (!hasSeenWarning && !isReturning) {
        document.getElementById('warningOverlay').classList.add('active');
        sessionStorage.setItem('hasSeenArticlesWarning', 'true');
    }
    
    // 分页功能
    var grid = document.getElementById('articleGrid');
    var pageButtons = document.querySelectorAll('.page[data-page]');
    var prevBtn = document.getElementById('prevBtn');
    var nextBtn = document.getElementById('nextBtn');
    var currentPage = 1;
    var postsPerPage = 9;
    var totalPages = pageButtons.length;
    
    console.log('Total pages:', totalPages, 'Total posts:', allPostsData.length);
    
    // 渲染指定页的卡片
    function renderPage(page) {
        var start = (page - 1) * postsPerPage;
        var end = Math.min(start + postsPerPage, allPostsData.length);
        var pagePosts = allPostsData.slice(start, end);
        
        console.log('Rendering page ' + page + ', posts ' + start + '-' + end);
        
        grid.innerHTML = '';
        pagePosts.forEach(function(post) {
            var card = document.createElement('div');
            card.className = 'card';
            card.setAttribute('data-slug', post.urlSlug);
            card.onclick = function() { navigateTo('/article/' + post.urlSlug); };
            
            var img = document.createElement('img');
            img.src = post.cover || ('https://picsum.photos/300/200?' + post.urlSlug);
            img.alt = post.title;
            
            var h3 = document.createElement('h3');
            h3.textContent = post.title;
            
            card.appendChild(img);
            card.appendChild(h3);
            grid.appendChild(card);
        });
        
        // 更新按钮状态
        pageButtons.forEach(function(btn) {
            btn.classList.remove('active');
        });
        if (pageButtons[page - 1]) {
            pageButtons[page - 1].classList.add('active');
        }
        
        currentPage = page;
    }
    
    // 页码按钮点击
    pageButtons.forEach(function(btn, index) {
        btn.addEventListener('click', function(e) {
            e.preventDefault();
            var pageNum = parseInt(this.getAttribute('data-page'));
            console.log('Clicked page button:', pageNum);
            renderPage(pageNum);
        });
    });
    
    // 上一页
    if (prevBtn) {
        prevBtn.addEventListener('click', function(e) {
            e.preventDefault();
            console.log('Clicked prev, currentPage:', currentPage);
            if (currentPage > 1) {
                renderPage(currentPage - 1);
            }
        });
    }
    
    // 下一页
    if (nextBtn) {
        nextBtn.addEventListener('click', function(e) {
            e.preventDefault();
            console.log('Clicked next, currentPage:', currentPage, 'totalPages:', totalPages);
            if (currentPage < totalPages) {
                renderPage(currentPage + 1);
            }
        });
    }
});

function closeWarning() {
    document.getElementById('warningOverlay').classList.remove('active');
}

function backToHome() {
    sessionStorage.removeItem('isReturningFromOtherPage');
    window.location.href = '/';
}
</script>
</BaseLayout>
