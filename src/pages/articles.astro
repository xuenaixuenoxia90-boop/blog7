---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { readFileSync } from 'fs';
import path from 'path';

const allPosts = await getCollection('blog');
const posts = [...allPosts].sort((a, b) => {
  const slugA = a.data.slug || a.slug;
  const slugB = b.data.slug || b.slug;
  return slugA.localeCompare(slugB);
});

const picturesPath = path.join(process.cwd(), 'src', 'content', 'pictures', 'pictures.md');
const picturesContent = readFileSync(picturesPath, 'utf-8');
const imageRegex = /!\[img\]\(([^)]+)\)/g;
const pictureUrls = [];
let match;
while ((match = imageRegex.exec(picturesContent)) !== null) {
  pictureUrls.push(match[1]);
}

function getPictureByIndex(index) {
  if (pictureUrls.length === 0) {
    return `https://picsum.photos/300/200?${index}`;
  }
  return pictureUrls[index % pictureUrls.length];
}

const postsPerPage = 9;
const totalPages = Math.ceil(posts.length / postsPerPage);
const firstPagePosts = posts.slice(0, postsPerPage);
const isReturning = true;
---

<BaseLayout title="挖洞吧" css={['articles.css']}>
<div class="container" id="mainContainer">
    <div class="side-space"></div>
    <div class="main" id="mainContent" style="display: none;">
        <div class="top-bar">
            <div class="top-left">
                <button class="back-btn" onclick="goBackToHome()">
                    <span class="arrow">←</span>
                    <span data-cn="返回" data-en="Back">返回</span>
                </button>
                <div class="header">
                    <h1 data-cn="挖洞吧" data-en="Hack Zone">挖洞吧</h1>
                    <p data-cn="自己挖 + 市面上大部分漏洞报告，只要小白一直挖就一直更新！" data-en="Self-discovered vulnerabilities + most public reports. As long as White keeps digging, updates never stop!">
                        自己挖 + 市面上大部分漏洞报告，只要小白一直挖就一直更新！
                    </p>
                </div>
            </div>
            <div class="language-box">
                <button class="language-btn" id="currentLang"><span class="lang-icon"></span><span class="lang-text">简体中文</span></button>
                <div class="language-dropdown">
                    <button class="language-item" onclick="switchLanguage('zh')">简体中文</button>
                    <button class="language-item" onclick="switchLanguage('en')">English</button>
                </div>
            </div>
        </div>
        <div class="toolbar">
            <input type="text" id="searchInput" placeholder="搜索漏洞标题..." />
            <button class="search-btn" data-cn="🔍 搜索" data-en=" Search"> 搜索</button>
        </div>
        <div class="article-grid" id="articleGrid">
            {firstPagePosts.map((post, index) => {
              const title = post.data.title || post.slug;
              const cover = post.data.cover || getPictureByIndex(index);
              const urlSlug = post.data.slug || post.slug;
              return (
                <div class="card" data-slug={urlSlug}>
                  <img src={cover} alt={title} />
                  <h3>{title}</h3>
                </div>
              );
            })}
        </div>
        <div class="pagination" id="pagination">
            <button class="page-btn prev-btn" id="prevBtn">
                <span>‹</span> 上一页
            </button>
            <span class="page-label">第</span>
            <select class="page-select" id="pageSelect">
                {Array.from({ length: totalPages }, (_, i) => (
                    <option value={i + 1}>{i + 1}</option>
                ))}
            </select>
            <span class="page-label">页 / 共 {totalPages} 页</span>
            <button class="page-btn next-btn" id="nextBtn">
                下一页 <span>›</span>
            </button>
        </div>
    </div>
    <div class="side-space"></div>
</div>

<!-- 警告框 -->
<div class="warning-overlay" id="warningOverlay">
    <div class="warning-box">
        <div class="warning-icon">️</div>
        <div class="warning-title">警告</div>
        <div class="warning-text">公开漏洞报告分享平台收录的所有漏洞均已修复，仅用于网络安全学习，严禁用于任何非法用途！</div>
        <div class="warning-btns">
            <button class="warning-btn confirm-btn" onclick="closeWarning()">我已知悉，确认进入</button>
            <button class="warning-btn back-btn" onclick="backToHome()">返回</button>
        </div>
    </div>
</div>

<!-- 总页数数据 -->
<script id="total-pages" type="application/json">{totalPages}</script>

<script is:inline>
(function() {
    var pageCache = { 1: [] };
    var currentPage = 1;
    var totalPages = 1;
    var prevBtn = null;
    var nextBtn = null;
    var pageSelect = null;
    
    try {
        var totalPagesEl = document.getElementById('total-pages');
        if (totalPagesEl) {
            totalPages = parseInt(totalPagesEl.textContent);
        }
    } catch(e) {}
    
    var isReturning = sessionStorage.getItem('isReturningFromOtherPage') === 'true';
    var overlay = document.getElementById('warningOverlay');
    var main = document.getElementById('mainContent');
    
    if (isReturning) {
        if (overlay) {
            overlay.style.display = 'none';
        }
        if (main) {
            main.style.display = '';
        }
        sessionStorage.removeItem('isReturningFromOtherPage');
    } else {
        if (overlay) {
            overlay.classList.add('active');
        }
        if (main) {
            main.style.display = 'none';
        }
    }
    
    function renderCards(posts) {
        var grid = document.getElementById('articleGrid');
        grid.innerHTML = '';
        for (var i = 0; i < posts.length; i++) {
            var post = posts[i];
            var card = document.createElement('div');
            card.className = 'card';
            card.setAttribute('data-slug', post.urlSlug);
            
            var img = document.createElement('img');
            img.src = post.cover;
            img.alt = post.title;
            
            var h3 = document.createElement('h3');
            h3.textContent = post.title;
            
            card.appendChild(img);
            card.appendChild(h3);
            
            (function(p) {
                card.addEventListener('click', function() {
                    console.log('保存页码:', currentPage);
                    sessionStorage.setItem('articlesPage', String(currentPage));
                    window.location.href = '/article/' + p.urlSlug;
                });
            })(post);
            
            grid.appendChild(card);
        }
    }
    
    function updateUI(pageNum) {
        if (pageSelect) {
            pageSelect.value = String(pageNum);
        }
        if (prevBtn) prevBtn.disabled = (pageNum <= 1);
        if (nextBtn) nextBtn.disabled = (pageNum >= totalPages);
    }
    
    window.switchToPage = function(pageNum) {
        if (pageNum < 1 || pageNum > totalPages) return;
        currentPage = pageNum;
        updateUI(pageNum);
        
        if (pageCache[pageNum]) {
            var grid = document.getElementById('articleGrid');
            grid.innerHTML = '';
            for (var i = 0; i < pageCache[pageNum].length; i++) {
                grid.appendChild(pageCache[pageNum][i]);
            }
            return;
        }
        
        fetch('/api/posts/' + pageNum + '.json')
            .then(function(res) { return res.json(); })
            .then(function(data) {
                renderCards(data.posts);
                
                var grid = document.getElementById('articleGrid');
                var cards = [];
                var allCards = grid.querySelectorAll('.card');
                for (var j = 0; j < allCards.length; j++) {
                    cards.push(allCards[j]);
                }
                pageCache[pageNum] = cards;
            })
            .catch(function() {});
    };
    
    document.addEventListener('DOMContentLoaded', function() {
        prevBtn = document.getElementById('prevBtn');
        nextBtn = document.getElementById('nextBtn');
        pageSelect = document.getElementById('pageSelect');
        
        var firstPageCards = document.querySelectorAll('#articleGrid .card');
        var cachedCards = [];
        for (var i = 0; i < firstPageCards.length; i++) {
            var card = firstPageCards[i];
            (function(c) {
                c.addEventListener('click', function() {
                    sessionStorage.setItem('articlesPage', String(currentPage));
                    window.location.href = '/article/' + c.dataset.slug;
                });
            })(card);
            cachedCards.push(card);
        }
        pageCache[1] = cachedCards;
        
        updateUI(1);
        
        if (pageSelect) {
            pageSelect.addEventListener('change', function() {
                var pageNum = parseInt(this.value);
                window.switchToPage(pageNum);
            });
        }
        
        if (prevBtn) {
            prevBtn.addEventListener('click', function(e) {
                e.preventDefault();
                window.switchToPage(currentPage - 1);
            });
        }
        
        if (nextBtn) {
            nextBtn.addEventListener('click', function(e) {
                e.preventDefault();
                window.switchToPage(currentPage + 1);
            });
        }
        
        // 恢复之前保存的页码
        var savedPage = sessionStorage.getItem('articlesPage');
        console.log('恢复页码检查:', savedPage);
        if (savedPage) {
            var pageNum = parseInt(savedPage);
            sessionStorage.removeItem('articlesPage');
            console.log('准备切换到页码:', pageNum);
            if (pageNum > 1 && pageNum <= totalPages) {
                window.switchToPage(pageNum);
            }
        }
    });
    
    // 处理页面恢复（bfcache）
    window.addEventListener('pageshow', function(event) {
        if (event.persisted) {
            console.log('页面从缓存恢复');
            var savedPage = sessionStorage.getItem('articlesPage');
            console.log('恢复页码检查:', savedPage);
            if (savedPage) {
                var pageNum = parseInt(savedPage);
                sessionStorage.removeItem('articlesPage');
                console.log('准备切换到页码:', pageNum);
                if (pageNum > 1 && pageNum <= totalPages) {
                    window.switchToPage(pageNum);
                }
            }
        }
    });
})();

window.closeWarning = function() {
    var overlay = document.getElementById('warningOverlay');
    var main = document.getElementById('mainContent');
    overlay.style.opacity = '0';
    overlay.style.visibility = 'hidden';
    main.style.display = '';
};

window.backToHome = function() {
    window.location.href = '/';
};
</script>
</BaseLayout>