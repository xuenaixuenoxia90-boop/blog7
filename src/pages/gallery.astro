---
import BaseLayout from '../layouts/BaseLayout.astro';
import { readFileSync } from 'fs';
import { fileURLToPath } from 'url';
import { dirname, join } from 'path';

// 读取 pictures.md 文件并提取图片链接
const picturesPath = join(dirname(fileURLToPath(import.meta.url)), '../content/pictures/pictures.md');
const picturesContent = readFileSync(picturesPath, 'utf-8');

// 匹配 ![img](url) 格式提取图片链接
const imageRegex = /!\[img\]\(([^)]+)\)/g;
const images = [];
let match;
while ((match = imageRegex.exec(picturesContent)) !== null) {
  images.push(match[1]);
}

// 限制显示数量（避免过多图片导致页面加载慢）
const maxImages = 100;
const displayImages = images.slice(0, maxImages);
---

<BaseLayout title="赏图吧" css={['gallery.css']}>
<div class="page">
    <!-- 左广告 -->
    <div class="ad-left"></div>
    <!-- 中间 -->
    <div class="main">
        <!-- 顶部 -->
        <div class="header">
            <div class="top-row">
                <div class="left-wrap">
                    <button class="back-btn" onclick="goBackToHome()">
                        ← <span data-cn="返回" data-en="Back">返回</span>
                    </button>
                    <div class="logo-wrap">
                        <div class="logo" data-cn="赏图吧" data-en="Gallery">赏图吧</div>
                        <div class="desc" data-cn="此时无声胜有声" data-en="Silence speaks louder">此时无声胜有声</div>
                    </div>
                </div>
                <!-- 语言切换 -->
                <div class="language-box">
                    <button class="language-btn" id="currentLang">
                        <span class="lang-icon">🌐</span>
                        <span class="lang-text">简体中文</span>
                    </button>
                    <div class="language-dropdown">
                        <button class="language-item" onclick="switchLanguage('zh')">简体中文</button>
                        <button class="language-item" onclick="switchLanguage('en')">English</button>
                    </div>
                </div>
            </div>
        </div>
        <!-- 瀑布流 -->
        <div class="gallery">
            {displayImages.map((imgUrl) => (
              <div class="card">
                <img src={imgUrl} alt="Gallery Image" loading="lazy" />
              </div>
            ))}
        </div>
        {images.length > maxImages && (
          <div class="loading" data-cn={`共 ${images.length} 张图片，已显示前 ${maxImages} 张`} data-en={`Total ${images.length} images, showing first ${maxImages}`}>
            共 {images.length} 张图片，已显示前 {maxImages} 张
          </div>
        )}
        {images.length <= maxImages && (
          <div class="loading" data-cn="没有更多了～" data-en="No more~">没有更多了～</div>
        )}
    </div>
    <!-- 右广告 -->
    <div class="ad-right"></div>
</div>
</BaseLayout>
