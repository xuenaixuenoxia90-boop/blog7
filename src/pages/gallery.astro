---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="赏图吧" css={['gallery.css']}>
<div class="container">
    <!-- 左侧留空 -->
    <div class="side-space"></div>
    <!-- 主体 -->
    <div class="main">
        <!-- 顶部 -->
        <div class="top-bar">
            <!-- 返回 -->
            <button class="back-btn" onclick="goBackToHome()">
                <span class="arrow">←</span>
                <span data-cn="返回" data-en="Back">返回</span>
            </button>
            <!-- 标题 -->
            <div class="header">
                <h1 data-cn="赏图吧" data-en="Gallery">赏图吧</h1>
                <p data-cn="此时无声胜有声" data-en="Silence speaks louder">此时无声胜有声</p>
            </div>
            <!-- 语言切换 -->
            <div class="language-box">
                <button class="language-btn" id="currentLang"><span class="lang-icon">🌐</span><span class="lang-text">简体中文</span></button>
                <div class="language-dropdown">
                    <button class="language-item" onclick="switchLanguage('zh')">简体中文</button>
                    <button class="language-item" onclick="switchLanguage('en')">English</button>
                </div>
            </div>
        </div>
        <!-- 瀑布流 -->
        <div class="gallery">
            <div class="card"><img src="https://picsum.photos/500/700?20"></div>
            <div class="card"><img src="https://picsum.photos/500/400?21"></div>
            <div class="card"><img src="https://picsum.photos/500/600?22"></div>
            <div class="card"><img src="https://picsum.photos/500/500?23"></div>
            <div class="card"><img src="https://picsum.photos/500/650?24"></div>
            <div class="card"><img src="https://picsum.photos/500/450?25"></div>
            <div class="card"><img src="https://picsum.photos/500/550?26"></div>
            <div class="card"><img src="https://picsum.photos/500/700?27"></div>
            <div class="card"><img src="https://picsum.photos/500/400?28"></div>
            <div class="card"><img src="https://picsum.photos/500/620?29"></div>
            <div class="card"><img src="https://picsum.photos/500/480?30"></div>
            <div class="card"><img src="https://picsum.photos/500/720?31"></div>
            <div class="card"><img src="https://picsum.photos/500/520?32"></div>
            <div class="card"><img src="https://picsum.photos/500/580?33"></div>
            <div class="card"><img src="https://picsum.photos/500/460?34"></div>
            <div class="card"><img src="https://picsum.photos/500/640?35"></div>
            <div class="card"><img src="https://picsum.photos/500/540?36"></div>
            <div class="card"><img src="https://picsum.photos/500/680?37"></div>
            <div class="card"><img src="https://picsum.photos/500/420?38"></div>
            <div class="card"><img src="https://picsum.photos/500/660?39"></div>
        </div>
        <!-- 加载提示 -->
        <div class="loading" data-cn="没有更多了～" data-en="No more~">没有更多了～</div>
    </div>
    <!-- 右侧留空 -->
    <div class="side-space"></div>
</div>
</BaseLayout>
