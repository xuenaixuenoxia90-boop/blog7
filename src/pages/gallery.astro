---
import BaseLayout from '../layouts/BaseLayout.astro';
import { readFileSync } from 'fs';
import path from 'path';

// 使用 process.cwd() 获取项目根目录（不受编译输出路径影响）
const picturesPath = path.join(process.cwd(), 'src', 'content', 'pictures', 'pictures.md');
const picturesContent = readFileSync(picturesPath, 'utf-8');

// 匹配 ![img](url) 格式提取图片链接
const imageRegex = /!\[img\]\(([^)]+)\)/g;
const allImages = [];
let match;
while ((match = imageRegex.exec(picturesContent)) !== null) {
  allImages.push(match[1]);
}

// 每批加载的图片数量
const batchSize = 80;

// 首屏渲染的图片
const firstBatch = allImages.slice(0, batchSize);
---

<BaseLayout title="赏图吧" css={['gallery.css']}>
<div class="page">
    <!-- 左广告 -->
    <div class="ad-left"></div>
    <!-- 中间 -->
    <div class="main">
        <!-- 顶部 -->
        <div class="header">
            <div class="top-row">
                <div class="left-wrap">
                    <button class="back-btn" onclick="goBackToHome()">
                        ← <span data-cn="返回" data-en="Back">返回</span>
                    </button>
                    <div class="logo-wrap">
                        <div class="logo" data-cn="赏图吧" data-en="Gallery">赏图吧</div>
                        <div class="desc" data-cn="此时无声胜有声" data-en="Silence speaks louder">此时无声胜有声</div>
                    </div>
                </div>
                <!-- 语言切换 -->
                <div class="language-box">
                    <button class="language-btn" id="currentLang">
                        <span class="lang-icon">🌐</span>
                        <span class="lang-text">简体中文</span>
                    </button>
                    <div class="language-dropdown">
                        <button class="language-item" onclick="switchLanguage('zh')">简体中文</button>
                        <button class="language-item" onclick="switchLanguage('en')">English</button>
                    </div>
                </div>
            </div>
        </div>
        <!-- 瀑布流容器 -->
        <div class="gallery" id="galleryContainer">
            {firstBatch.map((imgUrl) => (
              <div class="card">
                <img src={imgUrl} alt="Gallery Image" loading="lazy" />
              </div>
            ))}
        </div>
        <!-- 加载更多按钮区域 -->
        <div class="load-more-area" id="loadMoreArea">
            <button class="load-more-btn" id="loadMoreBtn" onclick="loadMoreImages()">
                更多
            </button>
        </div>
    </div>
    <!-- 右广告 -->
    <div class="ad-right"></div>
</div>

<!-- 传递所有图片URL到前端 -->
<script id="all-gallery-images" type="application/json">{JSON.stringify(allImages)}</script>

<script>
// 从脚本标签读取所有图片URL
var allImages = [];
try {
    var scriptEl = document.getElementById('all-gallery-images');
    if (scriptEl) {
        allImages = JSON.parse(scriptEl.textContent);
    }
} catch(e) {
    console.error('Failed to load images:', e);
}

var batchSize = 80;
var loadedCount = allImages.length > batchSize ? batchSize : allImages.length;
var isLoading = false;
var loadMoreArea = document.getElementById('loadMoreArea');
var loadMoreBtn = document.getElementById('loadMoreBtn');
var galleryContainer = document.getElementById('galleryContainer');

// 如果图片总数不超过80张，隐藏按钮
if (allImages.length <= batchSize) {
    if (loadMoreArea) loadMoreArea.style.display = 'none';
}

// 加载更多图片
function loadMoreImages() {
    if (isLoading) return;
    if (loadedCount >= allImages.length) {
        if (loadMoreArea) {
            loadMoreArea.innerHTML = '<div class="loading" data-cn="共 ' + allImages.length + ' 张图片，已全部加载" data-en="Total ' + allImages.length + ' images, all loaded">共 ' + allImages.length + ' 张图片，已全部加载</div>';
        }
        return;
    }
    
    isLoading = true;
    if (loadMoreBtn) loadMoreBtn.textContent = '加载中...';
    
    // 获取下一批图片
    var nextBatch = allImages.slice(loadedCount, loadedCount + batchSize);
    
    if (nextBatch.length === 0) {
        isLoading = false;
        if (loadMoreArea) {
            loadMoreArea.innerHTML = '<div class="loading" data-cn="共 ' + allImages.length + ' 张图片，已全部加载" data-en="Total ' + allImages.length + ' images, all loaded">共 ' + allImages.length + ' 张图片，已全部加载</div>';
        }
        return;
    }
    
    // 渲染新图片
    var fragment = document.createDocumentFragment();
    nextBatch.forEach(function(imgUrl) {
        var card = document.createElement('div');
        card.className = 'card';
        var img = document.createElement('img');
        img.src = imgUrl;
        img.alt = 'Gallery Image';
        img.setAttribute('loading', 'lazy');
        card.appendChild(img);
        fragment.appendChild(card);
    });
    galleryContainer.appendChild(fragment);
    
    loadedCount += nextBatch.length;
    isLoading = false;
    
    // 更新按钮状态
    if (loadedCount >= allImages.length) {
        if (loadMoreArea) {
            loadMoreArea.innerHTML = '<div class="loading" data-cn="共 ' + allImages.length + ' 张图片，已全部加载" data-en="Total ' + allImages.length + ' images, all loaded">共 ' + allImages.length + ' 张图片，已全部加载</div>';
        }
    } else if (loadMoreBtn) {
        loadMoreBtn.textContent = '更多';
    }
}
</script>
</BaseLayout>
