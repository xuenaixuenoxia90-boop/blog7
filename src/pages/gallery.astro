---
import BaseLayout from '../layouts/BaseLayout.astro';
import { readFileSync } from 'fs';
import path from 'path';

// 使用 process.cwd() 获取项目根目录（不受编译输出路径影响）
const picturesPath = path.join(process.cwd(), 'src', 'content', 'pictures', 'pictures.md');
const picturesContent = readFileSync(picturesPath, 'utf-8');

// 匹配 ![img](url) 格式提取图片链接
const imageRegex = /!\[img\]\(([^)]+)\)/g;
const allImages = [];
let match;
while ((match = imageRegex.exec(picturesContent)) !== null) {
  allImages.push(match[1]);
}

// 每批加载的图片数量
const batchSize = 80;
const totalPages = Math.ceil(allImages.length / batchSize);

// 首屏渲染的图片
const firstBatch = allImages.slice(0, batchSize);

// 是否还有更多图片
const hasMore = allImages.length > batchSize;
---

<BaseLayout title="赏图吧" css={['gallery.css']}>
<div class="page">
    <!-- 左广告 -->
    <div class="ad-left"></div>
    <!-- 中间 -->
    <div class="main">
        <!-- 顶部 -->
        <div class="header">
            <div class="top-row">
                <div class="left-wrap">
                    <button class="back-btn" onclick="goBackToHome()">
                        ← <span data-cn="返回" data-en="Back">返回</span>
                    </button>
                    <div class="logo-wrap">
                        <div class="logo" data-cn="赏图吧" data-en="Gallery">赏图吧</div>
                        <div class="desc" data-cn="此时无声胜有声" data-en="Silence speaks louder">此时无声胜有声</div>
                    </div>
                </div>
                <!-- 语言切换 -->
                <div class="language-box">
                    <button class="language-btn" id="currentLang">
                        <span class="lang-icon">🌐</span>
                        <span class="lang-text">简体中文</span>
                    </button>
                    <div class="language-dropdown">
                        <button class="language-item" onclick="switchLanguage('zh')">简体中文</button>
                        <button class="language-item" onclick="switchLanguage('en')">English</button>
                    </div>
                </div>
            </div>
        </div>
        <!-- 瀑布流容器 -->
        <div class="gallery" id="galleryContainer">
            {firstBatch.map((imgUrl) => (
              <div class="card">
                <img src={imgUrl} alt="Gallery Image" loading="lazy" />
              </div>
            ))}
        </div>
        <!-- 加载更多按钮 -->
        {hasMore && (
          <div class="load-more-wrap" id="loadMoreWrap">
              <button class="load-more-btn" id="loadMoreBtn" onclick="loadMoreImages()">
                  加载更多图片
              </button>
          </div>
        )}
        <!-- 加载完成提示 -->
        {!hasMore && (
          <div class="loading" data-cn="没有更多了～" data-en="No more~">没有更多了～</div>
        )}
    </div>
    <!-- 右广告 -->
    <div class="ad-right"></div>
</div>

<!-- 传递总页数和总图片数到前端 -->
<script id="gallery-config" type="application/json">{"totalPages": {totalPages}, "total": {allImages.length}, "batchSize": {batchSize}}</script>

<script>
var currentPage = 1;
var totalPages = 1;
var totalImages = 0;
var batchSize = 80;
var isLoading = false;
var allLoaded = false;

// 读取配置数据
try {
    var configScript = document.getElementById('gallery-config');
    if (configScript) {
        var config = JSON.parse(configScript.textContent);
        totalPages = config.totalPages;
        totalImages = config.total;
        batchSize = config.batchSize;
    }
} catch(e) {
    console.error('Failed to load gallery config:', e);
}

// 检查是否全部加载完毕
if (totalPages <= 1) {
    allLoaded = true;
    var wrap = document.getElementById('loadMoreWrap');
    if (wrap) wrap.style.display = 'none';
}

var galleryContainer = document.getElementById('galleryContainer');

// 渲染图片到网格
function renderImages(images) {
    var fragment = document.createDocumentFragment();
    images.forEach(function(imgUrl) {
        var card = document.createElement('div');
        card.className = 'card';
        var img = document.createElement('img');
        img.src = imgUrl;
        img.alt = 'Gallery Image';
        img.setAttribute('loading', 'lazy');
        card.appendChild(img);
        fragment.appendChild(card);
    });
    galleryContainer.appendChild(fragment);
}

// 加载更多图片
function loadMoreImages() {
    if (isLoading || allLoaded) return;
    
    isLoading = true;
    var btn = document.getElementById('loadMoreBtn');
    if (btn) btn.textContent = '加载中...';
    
    var nextPage = currentPage + 1;
    
    fetch('/api/images/' + nextPage + '.json')
        .then(function(res) { return res.json(); })
        .then(function(data) {
            renderImages(data.images);
            currentPage = nextPage;
            isLoading = false;
            
            // 检查是否还有更多
            if (currentPage >= totalPages) {
                allLoaded = true;
                var wrap = document.getElementById('loadMoreWrap');
                if (wrap) {
                    wrap.innerHTML = '<div class="loading" data-cn="共 ' + totalImages + ' 张图片，已全部加载" data-en="Total ' + totalImages + ' images, all loaded">共 ' + totalImages + ' 张图片，已全部加载</div>';
                }
            } else {
                var btn = document.getElementById('loadMoreBtn');
                if (btn) btn.textContent = '加载更多图片';
            }
        })
        .catch(function(err) {
            console.error('Failed to load images:', err);
            isLoading = false;
            var btn = document.getElementById('loadMoreBtn');
            if (btn) btn.textContent = '加载失败，点击重试';
        });
}
</script>
</BaseLayout>
