---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const tools = await getCollection('tool');
  return tools.map((tool) => ({
    params: { slug: tool.slug },
    props: { tool },
  }));
}

const { tool } = Astro.props;
const { Content } = await render(tool);
---

<BaseLayout title={`${tool.data.title} - 工具分享`} css={['tool.css']}>
<div class="container">
    <!-- 左右留白 -->
    <div class="side"></div>
    <!-- 主区域 -->
    <div class="main">
        <!-- 顶部 -->
        <div class="top">
            <button class="back-btn" onclick="goBackToList('/tools')">
                <span>←</span>
                <span data-cn="返回" data-en="Back">返回</span>
            </button>
            <div class="header">
                <h1 data-cn="工具分享" data-en="Tool Share">工具分享</h1>
                <p data-cn="打造专属于你的最强挖洞环境！" data-en="Build your own strongest hacking environment!">打造专属于你的最强挖洞环境！</p>
            </div>
            <div class="language-box">
                <button class="language-btn" id="currentLang"><span class="lang-icon">🌐</span><span class="lang-text">简体中文</span></button>
                <div class="language-dropdown">
                    <button class="language-item" onclick="switchLanguage('zh')">简体中文</button>
                    <button class="language-item" onclick="switchLanguage('en')">English</button>
                </div>
            </div>
        </div>
        <!-- 内容 -->
        <div class="content">
            <!-- 工具展示 -->
            <div class="tools">
                <div class="tool-card">
                    <div class="tool-image"><img src={`https://picsum.photos/300/200?${tool.slug}`} /></div>
                    <div class="tool-name">{tool.data.title}</div>
                </div>
            </div>
            <!-- 工具介绍（从 Markdown 渲染） -->
            <div class="desc-box">
                <h2 data-cn="工具介绍" data-en="Tool Introduction">工具介绍</h2>
                <div class="markdown-content">
                  <Content />
                </div>
            </div>
            <div class="bottom-space"></div>
        </div>
    </div>
    <!-- 右侧留白 -->
    <div class="side"></div>
</div>
</BaseLayout>
