---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const videos = await getCollection('video');

  return videos.map((video) => ({
    params: { slug: video.slug },
    props: { video },
  }));
}

const { video } = Astro.props;
---

<BaseLayout title={`${video.data.title} - 拉杆吧`} css={['video.css']}>

<div class="page">

    <!-- 顶部 -->
    <div class="topbar">

        <!-- 左边 -->
        <div class="left-info">

            <button class="back-btn" onclick="goBackToList('/videos')">
                ←
                <span data-cn="返回" data-en="Back">返回</span>
            </button>

            <div class="logo-wrap">
                <div class="logo" data-cn="拉杆吧" data-en="SWUB Zone">
                    拉杆吧
                </div>

                <div class="desc"
                     data-cn="唤醒国男的街健梦！"
                     data-en="Wake up your street workout dream!">
                    唤醒国男的街健梦！
                </div>
            </div>

        </div>

        <!-- 右边 -->
        <div class="right-area">

            <div class="video-title">
                {video.data.title}
            </div>

            <div class="language-box">

                <button class="language-btn" id="currentLang">
                    <span class="lang-icon">🌐</span>
                    <span class="lang-text">简体中文</span>
                </button>

                <div class="language-dropdown">
                    <button class="language-item" onclick="switchLanguage('zh')">
                        简体中文
                    </button>

                    <button class="language-item" onclick="switchLanguage('en')">
                        English
                    </button>
                </div>

            </div>

        </div>

    </div>

    <!-- 视频区域 -->
    <div class="video-section">

        <div
            class="video-box portrait"
            id="videoBox"
            data-video={video.data.video_url || ''}
        >

            {video.data.video_url ? (

                <iframe
                    src={video.data.video_url}
                    frameborder="0"
                    allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
                    allowfullscreen
                    class="video-iframe"
                ></iframe>

            ) : (

                <>
                    <div class="play-btn" onclick="playVideo()">
                        <div class="play-icon"></div>
                    </div>

                    <div
                        class="video-text"
                        data-cn="VIDEO"
                        data-en="VIDEO"
                    >
                        VIDEO
                    </div>
                </>

            )}

        </div>

    </div>

</div>

<script>

function playVideo() {

    const box = document.getElementById('videoBox');

    const videoUrl = box.getAttribute('data-video');

    if(videoUrl){

        box.innerHTML = `
            <iframe
                src="${videoUrl}"
                frameborder="0"
                allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
                allowfullscreen
                class="video-iframe"
            ></iframe>
        `;
    }
}

</script>

<style>

/* 全局 */

*{
    margin:0;
    padding:0;
    box-sizing:border-box;
}

body{
    font-family:
    "Microsoft YaHei",
    sans-serif;

    background:
    url('/images/bg.jpg')
    center center / cover
    no-repeat fixed;

    overflow-x:hidden;
}

/* 页面 */

.page{
    width:100%;
    min-height:100vh;

    backdrop-filter:blur(8px);

    padding-bottom:40px;
}

/* 顶部 */

.topbar{

    width:100%;

    display:flex;

    justify-content:space-between;

    align-items:flex-start;

    padding:
    30px
    50px;

}

/* 左边 */

.left-info{
    display:flex;
    align-items:flex-start;
    gap:20px;
}

/* 返回按钮 */

.back-btn{

    border:none;

    background:
    rgba(255,255,255,.12);

    color:white;

    padding:
    12px
    22px;

    border-radius:16px;

    cursor:pointer;

    font-size:18px;

    backdrop-filter:blur(10px);

    transition:.3s;
}

.back-btn:hover{

    background:
    rgba(255,255,255,.22);

    transform:translateY(-2px);
}

/* LOGO */

.logo{
    color:white;

    font-size:72px;

    font-weight:900;

    line-height:1;
}

.desc{

    margin-top:10px;

    color:
    rgba(255,255,255,.9);

    font-size:28px;
}

/* 右边 */

.right-area{
    text-align:right;
}

/* 标题 */

.video-title{

    color:white;

    font-size:64px;

    font-weight:900;

    margin-bottom:20px;

    text-shadow:
    0 0 20px
    rgba(0,0,0,.4);
}

/* 语言切换 */

.language-box{
    position:relative;
}

.language-btn{

    border:none;

    background:
    rgba(255,255,255,.12);

    color:white;

    padding:
    12px
    20px;

    border-radius:16px;

    cursor:pointer;

    font-size:16px;

    backdrop-filter:blur(10px);
}

.language-dropdown{

    display:none;

    position:absolute;

    right:0;

    top:60px;

    background:
    rgba(0,0,0,.7);

    border-radius:16px;

    overflow:hidden;

    backdrop-filter:blur(20px);
}

.language-box:hover .language-dropdown{
    display:block;
}

.language-item{

    width:100%;

    border:none;

    background:none;

    color:white;

    padding:
    14px
    20px;

    cursor:pointer;

    transition:.3s;
}

.language-item:hover{
    background:
    rgba(255,255,255,.1);
}

/* 视频区域 */

.video-section{

    width:100%;

    display:flex;

    justify-content:center;

    align-items:center;

    padding:
    20px
    30px
    50px;
}

/* 视频盒子 */

.video-box{

    position:relative;

    width:100%;

    background:black;

    border-radius:32px;

    overflow:hidden;

    box-shadow:
    0 0 60px rgba(0,0,0,.45);

}

/* 竖屏视频 */

.video-box.portrait{

    max-width:430px;

    aspect-ratio:9/16;
}

/* 横屏视频 */

.video-box.landscape{

    max-width:1500px;

    aspect-ratio:16/9;
}

/* iframe */

.video-iframe{

    width:100%;

    height:100%;

    border:none;

    display:block;
}

/* 播放按钮 */

.play-btn{

    position:absolute;

    top:50%;
    left:50%;

    transform:
    translate(-50%,-50%);

    width:120px;
    height:120px;

    border-radius:50%;

    background:
    rgba(255,255,255,.15);

    backdrop-filter:blur(10px);

    display:flex;

    justify-content:center;

    align-items:center;

    cursor:pointer;

    transition:.3s;
}

.play-btn:hover{

    transform:
    translate(-50%,-50%)
    scale(1.08);

    background:
    rgba(255,255,255,.25);
}

/* 三角 */

.play-icon{

    width:0;
    height:0;

    border-top:24px solid transparent;
    border-bottom:24px solid transparent;
    border-left:40px solid white;

    margin-left:8px;
}

/* VIDEO文字 */

.video-text{

    position:absolute;

    bottom:30px;

    left:50%;

    transform:translateX(-50%);

    color:
    rgba(255,255,255,.5);

    font-size:42px;

    letter-spacing:8px;
}

/* 手机端 */

@media(max-width:768px){

    .topbar{

        flex-direction:column;

        gap:20px;

        padding:
        20px;
    }

    .logo{
        font-size:48px;
    }

    .desc{
        font-size:18px;
    }

    .video-title{
        font-size:34px;
        text-align:left;
    }

    .right-area{
        width:100%;
    }

    .video-box.portrait{
        max-width:100%;
    }

}

</style>
