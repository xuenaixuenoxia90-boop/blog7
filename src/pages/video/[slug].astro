---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const videos = await getCollection('video');
  return videos.map((video) => ({
    params: { slug: video.slug },
    props: { video },
  }));
}

const { video } = Astro.props;
---

<BaseLayout title={`${video.data.title} - 拉杆吧`} css={['video.css']}>
<div class="page">
    <!-- 顶部 -->
    <div class="topbar">
        <!-- 左边 -->
        <div class="left-info">
            <button class="back-btn" onclick="goBackToList('/videos')">← <span data-cn="返回" data-en="Back">返回</span></button>
            <div class="logo-wrap">
                <div class="logo" data-cn="拉杆吧" data-en="SWUB Zone">拉杆吧</div>
                <div class="desc" data-cn="唤醒国男的街健梦！" data-en="Wake up your street workout dream!">唤醒国男的街健梦！</div>
            </div>
        </div>
        <!-- 右边 -->
        <div class="right-area">
            <div class="video-title">{video.data.title}</div>
            <div class="language-box">
                <button class="language-btn" id="currentLang"><span class="lang-icon">🌐</span><span class="lang-text">简体中文</span></button>
                <div class="language-dropdown">
                    <button class="language-item" onclick="switchLanguage('zh')">简体中文</button>
                    <button class="language-item" onclick="switchLanguage('en')">English</button>
                </div>
            </div>
        </div>
    </div>
    <!-- 中央视频播放器 -->
    <div class="video-section">
        <div class="video-box">
            <div class="video-container" id="videoBox" data-video={video.data.video_url || ''}>
                {video.data.video_url ? (
                  <video
                    src={video.data.video_url}
                    controls
                    preload="metadata"
                    autoplay
                    playsinline
                    class="video-player"
                  ></video>
                ) : (
                  <>
                    <div class="play-btn" onclick="playVideo()">
                        <div class="play-icon"></div>
                    </div>
                    <div class="video-text" data-cn="VIDEO" data-en="VIDEO">VIDEO</div>
                  </>
                )}
            </div>
        </div>
    </div>
    <script>
      function playVideo() {
        const box = document.getElementById('videoBox');
        const videoUrl = box.getAttribute('data-video');
        if (videoUrl) {
          box.innerHTML = '<video src="' + videoUrl + '" controls preload="metadata" autoplay playsinline class="video-player" id="dynamicVideo"></video>';
          var vid = document.getElementById('dynamicVideo');
          vid.addEventListener('loadedmetadata', function() {
            var ratio = vid.videoHeight / vid.videoWidth;
            box.style.aspectRatio = vid.videoWidth + '/' + vid.videoHeight;
            if (ratio > 1) {
              box.style.maxWidth = '70vh';
            }
          });
        }
      }
      
      document.addEventListener('DOMContentLoaded', function() {
        var player = document.querySelector('.video-player');
        if (player) {
          var box = document.getElementById('videoBox');
          player.addEventListener('loadedmetadata', function() {
            var ratio = player.videoHeight / player.videoWidth;
            if (player.videoHeight > player.videoWidth) {
              box.style.aspectRatio = player.videoWidth + '/' + player.videoHeight;
              box.style.maxWidth = '70vh';
            }
          });
        }
      });
    </script>
</div>
</BaseLayout>
